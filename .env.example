# Adscore environment template
# Copy this file to `.env` and fill values.

# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase (required for auth + data)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_optional

# -----------------------------------------------------------------------------
# AI provider (required for chat/analysis generation)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# App / auth config
# -----------------------------------------------------------------------------
ADSCORE_PUBLIC_URL=http://localhost:3000
ADSCORE_OAUTH_STATE_SECRET=replace_with_long_random_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/meta/callback

# -----------------------------------------------------------------------------
# Optional analytics
# -----------------------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Optional ads platform server credentials
# -----------------------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
